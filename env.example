// SPDX-License-Identifier: MIT
pragma solidity ^0.8.19;

/**
 * @title VoterRegistry - On-Chain Voter Verification
 * @notice Manages voter registration and verification status on-chain
 * @dev Links wallet addresses to verified voter status
 * @author VoteOnChain Team
 */

contract VoterRegistry {
    // ============ Enums ============
    enum VerificationStatus { UNREGISTERED, PENDING, VERIFIED, REJECTED }

    // ============ Structs ============
    struct Voter {
        address walletAddress;
        bytes32 idHash; // Hash of ID document (privacy preserving)
        VerificationStatus status;
        uint256 registeredAt;
        uint256 verifiedAt;
        bool exists;
    }

    // ============ State Variables ============
    address public admin;
    address[] public verifiers; // Addresses authorized to verify voters
    uint256 public verifiedVoterCount;
    uint256 public pendingCount;
    uint256 public totalRegistered;

    // Mappings
    mapping(address => Voter) public voters;
    mapping(bytes32 => bool) public usedIdHashes; // Prevent double registration
    mapping(address => bool) public isVerifier;

    // ============ Events ============
    event VoterRegistered(
        address indexed voter,
        bytes32 idHash,
        uint256 timestamp
    );

    event VoterVerified(
        address indexed voter,
        address indexed verifier,
        uint256 timestamp
    );

    event VoterRejected(
        address indexed voter,
        address indexed verifier,
        string reason,
        uint256 timestamp
    );

    event VerifierAdded(address indexed verifier);
    event VerifierRemoved(address indexed verifier);

    // ============ Modifiers ============
    modifier onlyAdmin() {
        require(msg.sender == admin, "Only admin can perform this action");
        _;
    }

    modifier onlyVerifier() {
        require(
            isVerifier[msg.sender] || msg.sender == admin,
            "Only verifiers can perform this action"
        );
        _;
    }

    // ============ Constructor ============
    constructor() {
        admin = msg.sender;
        isVerifier[msg.sender] = true;
        verifiers.push(msg.sender);
    }

    // ============ Registration Functions ============

    /**
     * @notice Register as a voter with hashed ID
     * @param _idHash Keccak256 hash of voter's ID document
     */
    function register(bytes32 _idHash) external {
        require(!voters[msg.sender].exists, "Already registered");
        require(_idHash != bytes32(0), "Invalid ID hash");
        require(!usedIdHashes[_idHash], "ID already registered to another voter");

        voters[msg.sender] = Voter({
            walletAddress: msg.sender,
            idHash: _idHash,
            status: VerificationStatus.PENDING,
            registeredAt: block.timestamp,
            verifiedAt: 0,
            exists: true
        });

        usedIdHashes[_idHash] = true;
        totalRegistered++;
        pendingCount++;

        emit VoterRegistered(msg.sender, _idHash, block.timestamp);
    }

    /**
     * @notice Admin/Verifier can register a voter directly as verified
     * @param _voter Voter wallet address
     * @param _idHash Keccak256 hash of voter's ID document
     */
    function registerVerified(address _voter, bytes32 _idHash) external onlyVerifier {
        require(!voters[_voter].exists, "Already registered");
        require(_idHash != bytes32(0), "Invalid ID hash");
        require(!usedIdHashes[_idHash], "ID already registered");

        voters[_voter] = Voter({
            walletAddress: _voter,
            idHash: _idHash,
            status: VerificationStatus.VERIFIED,
            registeredAt: block.timestamp,
            verifiedAt: block.timestamp,
            exists: true
        });

        usedIdHashes[_idHash] = true;
        totalRegistered++;
        verifiedVoterCount++;

        emit VoterRegistered(_voter, _idHash, block.timestamp);
        emit VoterVerified(_voter, msg.sender, block.timestamp);
    }

    // ============ Verification Functions ============

    /**
     * @notice Verify a pending voter
     * @param _voter Address of voter to verify
     */
    function verifyVoter(address _voter) external onlyVerifier {
        require(voters[_voter].exists, "Voter not registered");
        require(
            voters[_voter].status == VerificationStatus.PENDING,
            "Voter not in pending status"
        );

        voters[_voter].status = VerificationStatus.VERIFIED;
        voters[_voter].verifiedAt = block.timestamp;
        verifiedVoterCount++;
        pendingCount--;

        emit VoterVerified(_voter, msg.sender, block.timestamp);
    }

    /**
     * @notice Reject a pending voter
     * @param _voter Address of voter to reject
     * @param _reason Reason for rejection
     */
    function rejectVoter(address _voter, string memory _reason) external onlyVerifier {
        require(voters[_voter].exists, "Voter not registered");
        require(
            voters[_voter].status == VerificationStatus.PENDING,
            "Voter not in pending status"
        );

        voters[_voter].status = VerificationStatus.REJECTED;
        pendingCount--;

        emit VoterRejected(_voter, msg.sender, _reason, block.timestamp);
    }

    /**
     * @notice Allow rejected voter to re-register with new ID
     * @param _newIdHash New ID document hash
     */
    function reRegister(bytes32 _newIdHash) external {
        require(voters[msg.sender].exists, "Not registered");
        require(
            voters[msg.sender].status == VerificationStatus.REJECTED,
            "Can only re-register if rejected"
        );
        require(_newIdHash != bytes32(0), "Invalid ID hash");
        require(!usedIdHashes[_newIdHash], "ID already used");

        // Mark old hash as no longer blocking this voter
        // (they were rejected, so we allow new attempt)
        
        voters[msg.sender].idHash = _newIdHash;
        voters[msg.sender].status = VerificationStatus.PENDING;
        voters[msg.sender].registeredAt = block.timestamp;
        
        usedIdHashes[_newIdHash] = true;
        pendingCount++;

        emit VoterRegistered(msg.sender, _newIdHash, block.timestamp);
    }

    // ============ Admin Functions ============

    /**
     * @notice Add a new verifier
     * @param _verifier Address to add as verifier
     */
    function addVerifier(address _verifier) external onlyAdmin {
        require(!isVerifier[_verifier], "Already a verifier");
        require(_verifier != address(0), "Invalid address");
        
        isVerifier[_verifier] = true;
        verifiers.push(_verifier);
        
        emit VerifierAdded(_verifier);
    }

    /**
     * @notice Remove a verifier
     * @param _verifier Address to remove
     */
    function removeVerifier(address _verifier) external onlyAdmin {
        require(isVerifier[_verifier], "Not a verifier");
        require(_verifier != admin, "Cannot remove admin");
        
        isVerifier[_verifier] = false;
        
        // Remove from array
        for (uint256 i = 0; i < verifiers.length; i++) {
            if (verifiers[i] == _verifier) {
                verifiers[i] = verifiers[verifiers.length - 1];
                verifiers.pop();
                break;
            }
        }
        
        emit VerifierRemoved(_verifier);
    }

    /**
     * @notice Transfer admin rights
     * @param _newAdmin New admin address
     */
    function transferAdmin(address _newAdmin) external onlyAdmin {
        require(_newAdmin != address(0), "Invalid admin address");
        
        // Remove old admin from verifiers if not explicitly added
        isVerifier[admin] = false;
        
        admin = _newAdmin;
        
        // Add new admin as verifier
        if (!isVerifier[_newAdmin]) {
            isVerifier[_newAdmin] = true;
            verifiers.push(_newAdmin);
        }
    }

    // ============ View Functions ============

    /**
     * @notice Check if address is verified voter
     * @param _voter Address to check
     */
    function isVerified(address _voter) external view returns (bool) {
        return voters[_voter].status == VerificationStatus.VERIFIED;
    }

    /**
     * @notice Get voter details
     * @param _voter Address to query
     */
    function getVoter(address _voter)
        external
        view
        returns (
            VerificationStatus status,
            uint256 registeredAt,
            uint256 verifiedAt,
            bool exists
        )
    {
        Voter storage voter = voters[_voter];
        return (
            voter.status,
            voter.registeredAt,
            voter.verifiedAt,
            voter.exists
        );
    }

    /**
     * @notice Get all verifiers
     */
    function getVerifiers() external view returns (address[] memory) {
        return verifiers;
    }

    /**
     * @notice Get registry statistics
     */
    function getStats()
        external
        view
        returns (
            uint256 total,
            uint256 verified,
            uint256 pending
        )
    {
        return (totalRegistered, verifiedVoterCount, pendingCount);
    }
}
